{
  "project": {
    "seed": 42,
    "device": "auto"
  },

  "paths": {
    "input_dir": "data/images",
    "output_root": "outputs",
    "cache_root": "cache"
  },

  "ingest": {
    "extensions": [".jpg", ".jpeg", ".png", ".webp"],
    "max_images": null
  },

  "embedding": {
    "method": "dinov2",

    "dinov2": {
      "model_id": "facebook/dinov2-base"
    },

    "batch_size": 32,
    "num_workers": 0,

    "store": {
      "format": "npy",
      "dtype": "float32",
      "l2_normalize": true
    },

    "preprocess": {
      "policy": "center_crop",
      "input_size": 224
    }
  },

  "clustering": {
    "space": "umap"
  },

  "umap": {
    "n_components": 2,
    "n_neighbors": 30,
    "min_dist": 0.1,
    "metric": "cosine",
    "random_state": 42
  },

  "hdbscan": {
    "min_cluster_size": 10,
    "min_samples": 10,
    "cluster_selection_epsilon": 0.0,
    "metric": "euclidean"
  },

  "evaluation": {
    "exclude_noise": true
  },

  "viz": {
    "bokeh": {
      "show_noise_default": true
    },
    "montage": {
      "n_per_cluster": 10,
      "max_clusters": 200,
      "include_noise": false
    }
  },

  "grid_search": {
    "enabled": true,
    "umap": {
      "n_neighbors": [15, 30, 50],
      "min_dist": [0.0, 0.1]
    },
    "hdbscan": {
      "min_cluster_size": [10, 20, 30],
      "min_samples": [5, 10]
    }
  },

  "export": {
    "date_stamp": "26-February-2026"
  }
}